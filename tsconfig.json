{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "outDir": "lib",
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "declaration": true,
    "allowJs": true,
    "removeComments": false,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "test/**/*",
    "examples/**/*",
    "cjs/**/*",
    "esm/**/*"
  ]
}
